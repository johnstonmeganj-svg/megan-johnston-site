---
layout: base.njk
permalink: "about/"
navActive: about
title: "About Megan Johnston — Bozeman, MT Production Assistant"
description: "Megan Johnston is a Bozeman, MT 1st AD and production support professional, connected to local Montana crews, vendors, and locations."
ogType: profile
ogTitle: "About Megan Johnston — Bozeman, Montana Production Assistant & 1st AD"
ogDescription: "1st AD and production support work across Montana and nationwide, backed by a background in business and marketing."
---
<section class="hero">
  <div class="wrap">
    <span class="tag">About</span>
    <h1>The short version.</h1>
    <p class="lede">{{ about.lede }}</p>
  </div>
</section>

{% if about.portrait %}
<section>
  <div class="wrap">
    <img src="{{ about.portrait }}" alt="{{ about.portraitAlt or 'Megan Johnston' }}" style="display:block; width:100%; max-width:420px; height:auto; border-radius:var(--radius); border:3px solid var(--black);">
  </div>
</section>
{% endif %}

<section>
  <div class="wrap">
    <h2>{{ about.cardsHeading }}</h2>
    <div class="reasons-grid reasons-grid-cards">
      {% for card in about.cards %}
      <div class="reason-item reason-card reason-card-{{ card.color }}">
        <h3>{{ card.text }}</h3>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<section class="cta-banner">
  <div class="wrap">
    <h2>{{ about.ctaHeading }}</h2>
    <p>{{ about.ctaBody }}</p>
    <a class="btn" href="/contact/">{{ about.ctaButton }} &rarr;</a>
  </div>
</section>
