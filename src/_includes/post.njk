---
layout: base.njk
schema: article
ogType: article
---
<section>
  <div class="wrap post-header">
    <div class="meta">{{ category }}</div>
    <h1>{{ heading or title }}</h1>
  </div>
</section>

<section>
  <div class="wrap post-body">
    {% if photo %}<img src="{{ photo }}" alt="{{ photoAlt or title }}" class="post-photo">{% endif %}
    {{ content | safe }}
  </div>
</section>
