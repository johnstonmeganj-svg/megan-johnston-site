---
layout: base.njk
permalink: "index.html"
navActive: home
schema: person
title: "Megan Johnston — Bozeman, MT Production Assistant & 1st AD"
description: "Megan Johnston is a Bozeman, MT production assistant, 1st AD, and production coordinator working narrative and commercial productions statewide and nationwide."
ogTitle: "Megan Johnston — Bozeman, Montana Production Assistant & 1st AD"
ogDescription: "Bozeman, Montana-based. Open to production opportunities in narrative and commercial work, statewide and nationwide."
---
<div class="above-fold">
  <section class="hero hero-tall">
    <div class="wrap">
      <h1 class="hero-name"><span>{{ home.heroFirstName }}</span><span>{{ home.heroLastName }}</span></h1>
      <p class="hero-tagline">{{ home.heroTagline }}</p>
    </div>
  </section>

  <div class="ticker">
    <div class="ticker-track">
      {% for rep in ["a","b","c"] %}{% for phrase in home.tickerPhrases %}<span class="ticker-item">{{ phrase }}</span>{% endfor %}{% endfor %}
    </div>
  </div>
</div>
</div>

<section>
  <div class="wrap">
    <h2>Selected work.</h2>
    <div class="highlight-cards">
      {% for item in home.selectedWork %}
      <div class="highlight-card">
        <span class="credit-tag">{{ item.tag }}</span>
        <h3>{{ item.title }}</h3>
        <p>{{ item.role }}</p>
      </div>
      {% endfor %}
    </div>
    <p style="margin-top:32px;"><a href="/work/">Full credit list &rarr;</a></p>
  </div>
</section>

<section class="section-yellow">
  <div class="wrap">
    <h2>{{ home.notesHeading }}</h2>
    {% for post in collections.notes %}{% if loop.index <= 2 %}
    <article class="post-preview">
      <div class="meta">{{ post.data.category }}</div>
      <h3><a href="{{ post.url }}">{{ post.data.heading or post.data.title }}</a></h3>
      <p>{{ post.data.excerpt }}</p>
      <a href="{{ post.url }}">Read more &rarr;</a>
    </article>
    {% endif %}{% endfor %}
    <p style="margin-top:12px;"><a href="/notes/">Explore more from the field &rarr;</a></p>
  </div>
</section>

<section class="cta-banner">
  <div class="wrap">
    <h2>{{ home.ctaHeading }}</h2>
    <p>{{ home.ctaBody }}</p>
    <a class="btn" href="/contact/">{{ home.ctaButton }} &rarr;</a>
  </div>
</section>
